# Required for training pipeline (signal extraction, clustering, persona synthesis)
# Uses DeepSeek-V3 via OpenRouter — cheap for bulk review processing
# Get key: https://openrouter.ai/keys
# Supports multiple comma-separated keys for parallel extraction (up to 10 concurrent)
# Example: OPENROUTER_API_KEY=sk-or-key1,sk-or-key2,sk-or-key3
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Required ONLY if you want to run the persona agent (browsing websites) or insights/chat
# Get key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
